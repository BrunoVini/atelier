<!-- atelier reads this canonical block FIRST (it's the machine-readable contract);
     the prose below is for humans. Keep them in sync — or delete this block to let
     the tools parse the prose tables. Run `contract.py --validate <repo>` to check.
     MUST be valid JSON: colors are hex strings; SPACING_SCALE_JSON is a quoted,
     comma-separated list, e.g. "4px", "8px", "16px", "24px".
     If the system ships a co-equal DARK theme, fill the `dark` map below with the
     dark palette (same roles, hex) — `audit_contrast.py` and `contract.py` then
     ENFORCE the dark tokens too, instead of leaving them prose-only. DELETE the
     entire `dark` block for a light-only system. -->
```json atelier-contract
{
  "colors": {
    "primary": "{{COLOR_PRIMARY}}", "on-primary": "{{ON_PRIMARY}}",
    "secondary": "{{COLOR_SECONDARY}}", "on-secondary": "{{ON_SECONDARY}}",
    "accent": "{{COLOR_ACCENT}}", "on-accent": "{{ON_ACCENT}}",
    "background": "{{COLOR_BG}}", "foreground": "{{COLOR_FG}}",
    "muted": "{{COLOR_MUTED}}", "on-muted": "{{ON_MUTED}}",
    "border": "{{COLOR_BORDER}}",
    "destructive": "{{COLOR_DESTRUCTIVE}}", "on-destructive": "{{ON_DESTRUCTIVE}}"
  },
  "dark": {
    "primary": "{{DARK_PRIMARY}}", "on-primary": "{{DARK_ON_PRIMARY}}",
    "background": "{{DARK_BG}}", "foreground": "{{DARK_FG}}",
    "muted": "{{DARK_MUTED}}", "on-muted": "{{DARK_ON_MUTED}}",
    "border": "{{DARK_BORDER}}",
    "destructive": "{{DARK_DESTRUCTIVE}}", "on-destructive": "{{DARK_ON_DESTRUCTIVE}}"
  },
  "fonts": ["{{FONT_DISPLAY}}", "{{FONT_BODY}}"],
  "spacing": [{{SPACING_SCALE_JSON}}],
  "depth": "{{DEPTH_STRATEGY}}",
  "register": "{{REGISTER}}"
}
```
<!-- `register`: "brand" (design IS the product — landing/marketing/portfolio) or
     "product" (design SERVES the product — app UI/dashboard/settings/tools). It
     modulates QA severity for this surface (see references/registers/). When ambiguous,
     "product" is the safer default; brand is opt-in. Delete the key to leave it unset. -->
<!-- OPTIONAL (additive) — a machine-readable type ramp, named scale maps, + component
     minimums. All keys are surfaced verbatim by contract.py; omit them for a lean
     contract. To use them, paste the keys INTO the JSON block above (valid JSON):

  "typography": {
    "display-xl": { "fontFamily": "Sora, serif", "fontSize": "64px", "fontWeight": 400,
                    "lineHeight": 1.05, "letterSpacing": "-1.5px", "features": ["ss01", "tnum"] },
    "body-md":    { "fontFamily": "Inter, sans-serif", "fontSize": "16px", "fontWeight": 400,
                    "lineHeight": 1.55, "letterSpacing": "0" }
  },
  "rounded": { "sm": "6px", "md": "10px", "lg": "14px", "full": "9999px" },
  "shadows": { "sm": "0 1px 2px rgba(0,0,0,.06)", "overlay": "0 8px 24px rgba(0,0,0,.18)" },
  "components": {
    "button-primary": { "backgroundColor": "{colors.primary}", "textColor": "{colors.on-primary}",
                        "typography": "{typography.body-md}", "rounded": "{rounded.md}",
                        "padding": "12px 20px", "height": "40px" }
  }

     `features` is a LIST of OpenType tags (e.g. ["ss01","tnum"]); accepts Stitch camelCase
     (fontFamily/fontSize/...) or atelier snake_case (font/size/weight/line_height/tracking).

     CONTRACT-CLOSURE RULE (enforced): if you declare `components`, every `{group.name}`
     token they reference MUST resolve against a scale defined IN this block — colors (or
     `dark`), `typography`, `rounded`/`radii`, `shadows`. A component styled by
     `{rounded.md}` while no `rounded` map exists is a DANGLING ref; `contract.py --validate`
     reports it as `component_ref_issues` and FAILS the contract. So define the named maps
     (`rounded`, `shadows`) in the block too — don't leave radii/shadows prose-only while
     components point at them. Define each interaction state you want enforceable as its
     own component entry (e.g. `button-primary-hover`, `text-input-error`,
     `tide-chart-loading`) so a linter can read the whole state machine, not just rest. -->
<!-- NOTE: the legacy `spacing` list (the range engine slides it) is a LIST; `rounded` is
     a NAMED map components resolve against. Keep both: spacing values + named radii. -->


